{
  "name": "n8n-nodes-oido",
  "version": "0.8.0",
  "description": "n8n community nodes for Oido Studio — call Oido agents and trigger workflows from Oido events.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "oido",
    "oido-studio",
    "ai-agent"
  ],
  "license": "MIT",
  "homepage": "https://oidostudio.com",
  "author": {
    "name": "Oido Studio"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/oido-studio/n8n-nodes-oido.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && for d in nodes/*/; do cp \"${d}oido.svg\" \"dist/$d\"; done",
    "dev": "tsc --watch",
    "lint": "eslint nodes credentials",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/OidoApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Oido/Oido.node.js",
      "dist/nodes/OidoTrigger/OidoTrigger.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.3",
    "n8n-workflow": "^1.0.0",
    "typescript": "^5.4.0"
  }
}
